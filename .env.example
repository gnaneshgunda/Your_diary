# ─── YourDiary Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens.
# Generate a secure value: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Leave EMPTY to use local SQLite (yourdiary.db) — good for local development.
# Set to a PostgreSQL connection string for production persistence.
#
# Format:  postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#
# Free PostgreSQL providers:
#   Supabase → https://supabase.com  (500 MB free)
#   Neon     → https://neon.tech     (0.5 GB free, serverless)
#   Railway  → https://railway.app   (PostgreSQL addon)
#
# Example (Supabase):
#   DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Example (Neon):
#   DATABASE_URL=postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
