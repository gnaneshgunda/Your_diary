# ─── YourDiary Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# ── API Base URL ──────────────────────────────────────────────────────────────
# URL of your FastAPI backend.
# Local dev:   http://localhost:8000
# Production:  https://your-yourdiary-api.onrender.com
VITE_API_URL=https://your-yourdiary-api.onrender.com
